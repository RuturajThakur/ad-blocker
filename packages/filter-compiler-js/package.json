{
  "name": "@ad-blocker/filter-compiler-js",
  "version": "0.0.1",
  "private": true,
  "description": "TypeScript facade over the Rust/Wasm filter compiler. Exposes a Node build-time API and a browser/runtime API over the same Wasm core.",
  "type": "module",
  "exports": {
    "./node": {
      "types": "./node.ts",
      "default": "./node.ts"
    },
    "./web": {
      "types": "./web.ts",
      "default": "./web.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"TODO: wire eslint\" && exit 0"
  },
  "dependencies": {
    "filter-compiler-rs": "file:../filter-compiler-rs/pkg"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "vitest": "^2.1.0"
  }
}
