{
  "manifest_version": 3,
  "name": "Ad Blocker (dev)",
  "version": "0.0.1",
  "description": "Chrome MV3 ad blocker — development build.",
  "minimum_chrome_version": "120",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/service-worker/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Ad Blocker"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "easylist",
        "enabled": true,
        "path": "rulesets/easylist.json"
      },
      {
        "id": "easyprivacy",
        "enabled": true,
        "path": "rulesets/easyprivacy.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
