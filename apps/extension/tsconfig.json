{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // "chrome" for SW/content/popup code; "node" for scripts/build-rulesets.
    // Both sets are type-only — nothing here leaks into the shipped bundles.
    "types": ["chrome", "node"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "vite.config.ts"]
}
